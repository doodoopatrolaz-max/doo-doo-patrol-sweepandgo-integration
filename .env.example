# App
NODE_ENV=development
PORT=3000
WEBHOOK_PATH_SECRET=replace-with-sweepandgo-webhook-path-secret

# Database
DATABASE_URL=postgresql://placeholder-user:placeholder-password@placeholder-host:5432/placeholder-database

# Sweep&Go
# Leave this blank for the first Railway deployment. Add it only after Sweep&Go generates the token.
SWEEPGO_API_TOKEN=
SWEEPGO_BASE_URL=https://confirm-sweepandgo-base-url.example

# Future webhook placeholders. Leave blank until each provider is intentionally configured.
GOHIGHLEVEL_WEBHOOK_SECRET=
GMAIL_WEBHOOK_SECRET=
META_ADS_WEBHOOK_SECRET=
GOOGLE_ADS_WEBHOOK_SECRET=

# GoHighLevel reporting discovery placeholders. Do not add real credentials to this file.
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_PIPELINE_ID=
GHL_PIPELINE_NAME=Fresh Leads to Onboarding
GHL_FACEBOOK_STAGE_ID=
GHL_FACEBOOK_STAGE_NAME=Facebook New Lead
GHL_WEBSITE_STAGE_ID=
GHL_WEBSITE_STAGE_NAME=Website Quote Lead
META_ADS_ACCOUNT_ID=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_MANAGER_CUSTOMER_ID=
GMAIL_ONBOARDING_TO_ADDRESS=placeholder-internal-onboarding-address@example.com

# Daily dashboard report
DAILY_DASHBOARD_ENABLED=false
DAILY_DASHBOARD_RECIPIENT=placeholder-internal-report-recipient@example.com
DAILY_DASHBOARD_FROM=
DAILY_DASHBOARD_TIME_ZONE=America/Phoenix
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
