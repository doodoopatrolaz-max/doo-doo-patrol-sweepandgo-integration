# App
NODE_ENV=development
PORT=3000
WEBHOOK_PATH_SECRET=replace-with-a-long-random-value

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sweepandgo_integration

# Sweep&Go
# Leave this blank for the first Railway deployment. Add it only after Sweep&Go generates the token.
SWEEPGO_API_TOKEN=
SWEEPGO_BASE_URL=https://openapi.sweepandgo.com
